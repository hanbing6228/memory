# Database — PostgreSQL (Neon / Render / local Docker)
# Local example: postgresql://postgres:postgres@localhost:5432/memorial
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/memorial?sslmode=require"

# Auth — generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-random-32-bytes-minimum"

# App URL (production)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Optional: API base for GitHub Pages static mirror (defaults to same origin)
NEXT_PUBLIC_API_URL="https://your-app.vercel.app"

# Cron — openssl rand -hex 32
CRON_SECRET="change-me-cron-secret"

# Composio (https://app.composio.dev) — Gmail + Notion
COMPOSIO_API_KEY=""
COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=""
COMPOSIO_NOTION_CONNECTED_ACCOUNT_ID=""
NOTION_DATABASE_ID=""

# Email sender display
MEMORIAL_EMAIL_FROM="念归处 <noreply@yourdomain.com>"

# Hostinger deploy (GitHub Actions secrets)
DEPLOY_HOST=""
DEPLOY_USER="root"
DEPLOY_SSH_KEY=""
DEPLOY_PATH="/var/www/nianguichu"
