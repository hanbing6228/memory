[Unit]
Description=NianGuiChu Memorial Next.js
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/nianguichu
Environment=NODE_ENV=production
EnvironmentFile=/var/www/nianguichu/.env
ExecStart=/usr/bin/node /var/www/nianguichu/.next/standalone/server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
